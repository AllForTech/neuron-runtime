{
  "name": "neuron-runtime",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- turbo run dev",
    "build": "dotenv -e .env -- turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "start:api": "node apps/api/dist/apps/api/src/index.js",
    "start:web": "pnpm --filter frontend start",
    "start": "node node apps/api/dist/apps/api/src/index.js && pnpm --filter frontend start"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "tsup": "^8.0.1",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
