{
  "name": "@neuron/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./db": "./dist/client/index.js",
    "./types": "./dist/types/index.js",
    "./schemas": "./dist/schemas/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@neuron/auth": "workspace:*",
    "@neuron/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "drizzle-kit": "^0.31.9",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}