{
  "name": "@neuron/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },

  "files": ["dist"],

  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },

  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },

  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "clsx": "^2.1.1"
  },

  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "tsup": "^8.0.1"
  }
}