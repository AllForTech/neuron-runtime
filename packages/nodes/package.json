{
  "name": "@neuron/nodes",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/client/index.ts src/server/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/client/index.ts src/server/index.ts --format esm --dts --watch --onSuccess 'echo \"Nodes Synced\"'"
  },
  "dependencies": {
    "@neuron/node-condition": "workspace:*",
    "@neuron/node-context": "workspace:*",
    "@neuron/node-debug": "workspace:*",
    "@neuron/node-decision": "workspace:*",
    "@neuron/node-http-request": "workspace:*",
    "@neuron/node-integration": "workspace:*",
    "@neuron/node-llm": "workspace:*",
    "@neuron/node-output": "workspace:*",
    "@neuron/node-respond": "workspace:*",
    "@neuron/node-transform": "workspace:*",
    "@neuron/node-trigger": "workspace:*",
    "@neuron/shared": "workspace:*",
    "server-only": "^0.0.1"
  }
}