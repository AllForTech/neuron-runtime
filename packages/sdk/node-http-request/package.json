{
  "name": "@neuron/node-http-request",
  "version": "1.0.0",
  "type": "module",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },

  "files": ["dist"],

  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts"
  },

  "dependencies": {
    "@neuron/shared": "workspace:*",
    "@neuron/nodes-sdk": "workspace:*"
  },

  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "tsup": "^8.0.1"
  }
}