{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "target": "es2021",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@neuron/shared": ["../../packages/shared/src/index.ts"],
      "@neuron/shared/*": ["../../packages/shared/src/*"],
      "@neuron/runtime": ["../../packages/runtime/src/index.ts"],
      "@neuron/nodes": ["../../packages/nodes/src/server/index.ts"],
      "@neuron/node-*": ["../../packages/sdk/node-*/src/index.ts"]
    },
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/runtime/src/**/*",
    "../../packages/nodes/src/**/*",
    "../../packages/sdk/*/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}