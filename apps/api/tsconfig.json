{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "target": "es2021",
    "module": "CommonJS",
    "moduleResolution": "node",

    "baseUrl": ".",
    "paths": {
      "@neuron/shared": ["../../packages/shared/dist"],
      "@neuron/shared/*": ["../../packages/shared/dist/*"]
    },

    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}