{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@neuron/shared": ["../../packages/shared/src/index.ts"],
      "@neuron/db": ["../../packages/db/src/index.ts"]
    },
    "skipLibCheck": true,
    "incremental": false,
    "tsBuildInfoFile": null,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2015", "es2021"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}